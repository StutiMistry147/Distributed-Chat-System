# Database Configuration
# Format: postgresql://username:password@host:port/database_name
# Replace 'yourpassword' with your actual PostgreSQL password
DATABASE_URL=sqlite:///./chat.db

# JWT Authentication
# Generate a strong random string - you can use: openssl rand -hex 32
# Or python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_super_secure_random_string_here_change_this_in_production

# Application Environment
# Options: development, staging, production
ENVIRONMENT=development

# SQLAlchemy Echo
# Set to 'true' to log all SQL queries (useful for debugging)
# Set to 'false' in production
SQL_ECHO=false

# Server Configuration
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000

# Frontend URL for CORS
# Your React/Vue/Next.js frontend address
FRONTEND_URL=http://localhost:3000

# Logging Level
# Options: debug, info, warning, error, critical
LOG_LEVEL=info

# Redis Configuration (for future message queue)
# REDIS_URL=redis://localhost:6379/0

# AI Service Configuration (for future)
GEMINI_API_KEY=AIzaSyBUxcrRUIZq0XJs5n0cUvcpcOlRSObLxHI
# VECTOR_DB_PATH=./data/faiss_index